# OneDrive / Graph API credentials
# Copy this file to .env (never commit .env) and fill in your values.
# On EC2, set these as environment variables in the task definition or
# via AWS Systems Manager Parameter Store / Secrets Manager.

# Azure AD tenant ID (GUID or primary domain, e.g. contoso.onmicrosoft.com)
AZURE_TENANT_ID=

# App Registration client ID (GUID) — found in Azure AD > App registrations
AZURE_CLIENT_ID=

# App Registration client secret — created under Certificates & secrets
AZURE_CLIENT_SECRET=

# OneDrive drive ID — retrieve via:
#   GET https://graph.microsoft.com/v1.0/drives  (or /me/drive)
#   Use Graph Explorer: https://developer.microsoft.com/graph/graph-explorer
ONEDRIVE_DRIVE_ID=

# Excel file item ID — retrieve via:
#   GET https://graph.microsoft.com/v1.0/drives/{driveId}/root:/path/to/FX_Rates.xlsx
#   The "id" field in the response is the file item ID.
ONEDRIVE_FILE_ID=

# Worksheet name to overwrite on every run (must already exist in the workbook)
ONEDRIVE_SHEET_NAME=FX_Rates
